process {
    withName: "BEDTOOLS_GENOMECOV" {
      memory = 120.Gb
      time = 1.h
    }

     withName: 'BOWTIE2_ALIGN' {
    	ext.args   = {
            [
            meta.read_group ? "--rg-id ${meta.id} --rg SM:${meta.id - ~/_T\d+$/} --rg PL:ILLUMINA --rg LB:${meta.id} --rg PU:1" : '',
            params.seq_center ? "--rg CN:${params.seq_center}" : '',
            '--very-sensitive', 
	    '-X 2000'
            ].join(' ').trim()
        }
     }
}

